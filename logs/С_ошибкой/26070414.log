06:15.891000-49217974,DBMSSQL,5,level=DEBUG,process=rphost,p:processName=test,OSThread=8264,t:clientID=438,t:applicationName=BackgroundJob,t:computerName=rilink,t:connectID=30,SessionID=3,Usr=DefUser,DBMS=DBMSSQL,DataBase=127.0.0.1\test,Trans=1,dbpid=51,Sql='INSERT INTO dbo._AccRgAT058 (_Period, _AccountRRef, _Fld57, _TurnoverDt59, _TurnoverCt60, _Turnover61, _Splitter) SELECT
T1.Period_,
T1.AccountRRef,
CAST(CAST(SUM(T1.Fld57_) AS NUMERIC(23, 0)) AS NUMERIC(16, 0)),
CAST(CAST(SUM(T1.TurnoverDt59_) AS NUMERIC(22, 0)) AS NUMERIC(16, 0)),
CAST(CAST(SUM(T1.TurnoverCt60_) AS NUMERIC(22, 0)) AS NUMERIC(16, 0)),
CAST(CAST(SUM(T1.Turnover61_) AS NUMERIC(23, 0)) AS NUMERIC(16, 0)),
CAST(0.0 AS NUMERIC(10, 0))
FROM (SELECT
? AS Period_,
T2._AccountRRef AS AccountRRef,
T2._Fld57 + T2._Turnover61 AS Fld57_,
CAST(0.0 AS NUMERIC(16, 0)) AS TurnoverDt59_,
CAST(0.0 AS NUMERIC(16, 0)) AS TurnoverCt60_,
CAST(0.0 AS NUMERIC(17, 0)) AS Turnover61_
FROM dbo._AccRgAT058 T2
WHERE T2._Period = ? AND (NOT (T2._Fld57 IS NULL))
UNION ALL SELECT
? AS Period_,
T3.AccountRRef AS AccountRRef,
CAST(0.0 AS NUMERIC(17, 0)) AS Fld57_,
CAST(SUM(T3.TurnoverDt59_) AS NUMERIC(16, 0)) AS TurnoverDt59_,
CAST(SUM(T3.TurnoverCt60_) AS NUMERIC(16, 0)) AS TurnoverCt60_,
CAST(SUM(T3.TurnoverDt59_ - T3.TurnoverCt60_) AS NUMERIC(17, 0)) AS Turnover61_
FROM (SELECT
T4._AccountDtRRef AS AccountRRef,
T4._Fld57 AS TurnoverDt59_,
CAST(0.0 AS NUMERIC(10, 0)) AS TurnoverCt60_
FROM dbo._AccRg56 T4
WHERE T4._Active = 0x01 AND (T4._Period >= ? AND T4._Period < ?) AND T4._AccountDtRRef <> 0x00000000000000000000000000000000
UNION ALL SELECT
T5._AccountCtRRef AS AccountRRef,
CAST(0.0 AS NUMERIC(10, 0)) AS TurnoverDt59_,
T5._Fld57 AS TurnoverCt60_
FROM dbo._AccRg56 T5
WHERE T5._Active = 0x01 AND (T5._Period >= ? AND T5._Period < ?) AND T5._AccountCtRRef <> 0x00000000000000000000000000000000) T3
GROUP BY T3.AccountRRef
HAVING (CAST(0.0 AS NUMERIC(17, 0))) <> 0.0 OR (CAST(SUM(T3.TurnoverDt59_) AS NUMERIC(16, 0))) <> 0.0 OR (CAST(SUM(T3.TurnoverCt60_) AS NUMERIC(16, 0))) <> 0.0 OR (CAST(SUM(T3.TurnoverDt59_ - T3.TurnoverCt60_) AS NUMERIC(17, 0))) <> 0.0) T1
GROUP BY T1.Period_,
T1.AccountRRef
HAVING (CAST(CAST(SUM(T1.Fld57_) AS NUMERIC(23, 0)) AS NUMERIC(16, 0))) <> 0.0 OR (CAST(CAST(SUM(T1.TurnoverDt59_) AS NUMERIC(22, 0)) AS NUMERIC(16, 0))) <> 0.0 OR (CAST(CAST(SUM(T1.TurnoverCt60_) AS NUMERIC(22, 0)) AS NUMERIC(16, 0))) <> 0.0 OR (CAST(CAST(SUM(T1.Turnover61_) AS NUMERIC(23, 0)) AS NUMERIC(16, 0))) <> 0.0
