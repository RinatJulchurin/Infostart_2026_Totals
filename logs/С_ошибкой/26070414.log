UNION ALL SELECT
CAST(0.0 AS NUMERIC(23, 0)),
T4._Fld57 AS Fld57_
FROM dbo._AccRg56 T4
WHERE (T4._Period >= ?) AND (T4._Period < ?) AND (T4._AccountDtRRef = ?)) T1
